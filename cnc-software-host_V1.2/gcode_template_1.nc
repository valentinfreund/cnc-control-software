; =========================================
; CNC Test-Programm: Spiraltasche
; =========================================
G90 G54
G17 G21 G94
M3 S5000 ; Spindel EIN, 5000 U/min
M8       ; Kuehlmittel EIN
G0 X0.000 Y0.000 Z10.000
; --- Start Anfahren ---
G0 X10.000 Y10.000
G0 Z2.000
; --- Ebene 1 (Z-2) ---
G1 Z-2.000 F300
G1 X90.000 Y10.000 F1500
G1 X90.000 Y90.000
G1 X10.000 Y90.000
G1 X10.000 Y20.000
G1 X80.000 Y20.000
G1 X80.000 Y80.000
G1 X20.000 Y80.000
G1 X20.000 Y30.000
G1 X70.000 Y30.000
G1 X70.000 Y70.000
G1 X30.000 Y70.000
G1 X30.000 Y40.000
G1 X60.000 Y40.000
G1 X60.000 Y60.000
G1 X40.000 Y60.000
G1 X40.000 Y50.000
G1 X50.000 Y50.000
; --- Rueckzug Ebene 1 ---
G0 Z2.000
G0 X10.000 Y10.000
; --- Ebene 2 (Z-4) ---
G1 Z-4.000 F300
G1 X90.000 Y10.000 F1500
G1 X90.000 Y90.000
G1 X10.000 Y90.000
G1 X10.000 Y20.000
G1 X80.000 Y20.000
G1 X80.000 Y80.000
G1 X20.000 Y80.000
G1 X20.000 Y30.000
G1 X70.000 Y30.000
G1 X70.000 Y70.000
G1 X30.000 Y70.000
G1 X30.000 Y40.000
; --- Programmende ---
G0 Z10.000
M5 ; Spindel AUS
M9 ; Kuehlmittel AUS
M30 ; Programm Ende
